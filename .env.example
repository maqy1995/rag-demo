# ───── RAG demo env template ─────
# Copy to .env and fill in real values. NEVER commit .env.

# ADR-0001 + NI1 (MAQ-19 review): .env 只放 API key / base URL 等敏感字段.
# 配置字段 (provider / model / top_k / chunk_size / data_dir / index_dir 等)
# 走 config.yaml — 不要在这里写.

# ── LLM API keys (4 家 OpenAI 兼容, 分别命名; 填你用的那几家) ──
OPENAI_API_KEY=
ZHIPU_API_KEY=
MIMAX_API_KEY=
MIMO_API_KEY=

# Multica runtime (optional: only needed if the demo calls multica APIs)
# Copy from `multica session token print` if you want this.
MULTICA_TOKEN=
MULTICA_BASE_URL=https://api.multica.ai
