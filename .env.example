# ───── RAG demo env template ─────
# Copy to .env and fill in real values. NEVER commit .env.

# Embedding & LLM provider — pick one
LLM_PROVIDER=openai            # openai | anthropic
EMBEDDING_PROVIDER=openai      # openai | local
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# API keys — only set what you actually use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Multica runtime (optional: only needed if the demo calls multica APIs)
# Copy from `multica session token print` if you want this.
MULTICA_TOKEN=
MULTICA_BASE_URL=https://api.multica.ai

# Retrieval
VECTOR_STORE=faiss              # faiss | chroma | in-memory
TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Knowledge base
DATA_DIR=./data/raw
INDEX_DIR=./data/index
